#!/usr/bin/env bash

# Read session data from stdin (provided by Claude Code)
input=$(cat)

state_file="$HOME/.claude-active-profile"

if [[ ! -f "$state_file" ]]; then
    exit 0
fi

name=""
color=""
config_dir=""
emoji=""
{ read -r name; read -r color; read -r config_dir; read -r emoji; } < "$state_file"

declare -A colors=([red]=31 [green]=32 [yellow]=33 [blue]=34 [magenta]=35 [cyan]=36 [white]=37)
code="${colors[$color]:-37}"
dot="${emoji:-👤}"

# Helper: threshold color (light green < 50, light yellow < 80, light red >= 80)
pct_color() {
    local pct="${1%.*}"
    if   (( pct >= 80 )); then printf '\033[91m'
    elif (( pct >= 50 )); then printf '\033[93m'
    else                       printf '\033[92m'
    fi
}

# Profile segment
printf "%s \033[${code}m${name^}\033[0m" "$dot"

# Git branch segment
branch=$(git branch --show-current 2>/dev/null)
if [[ -n "$branch" ]]; then
    dirty=""
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        dirty="*"
    fi
    printf "  \033[36m⎇ %s%s\033[0m" "$branch" "$dirty"
fi

# Session data segments
if command -v jq &>/dev/null && [[ -n "$input" ]]; then
    cost=$(printf '%s' "$input" | jq -r '.cost.total_cost_usd // 0')
    if [[ "$cost" != "0" && "$cost" != "null" ]]; then
        printf "  \033[38;5;208m💰\$%.4f\033[0m" "$cost"
    fi

    ctx=$(printf '%s' "$input" | jq -r '.context_window.used_percentage // empty')
    if [[ -n "$ctx" ]]; then
        printf "  $(pct_color "$ctx")🪟%.0f%%\033[0m" "$ctx"
    fi

    duration_ms=$(printf '%s' "$input" | jq -r '.cost.total_duration_ms // 0')
    if [[ "$duration_ms" -gt 0 ]]; then
        mins=$(( duration_ms / 60000 ))
        secs=$(( (duration_ms % 60000) / 1000 ))
        printf "  \033[97m⏱ %dm%02ds\033[0m" "$mins" "$secs"
    fi

    rate=$(printf '%s' "$input" | jq -r '.rate_limits.five_hour.used_percentage // empty')
    if [[ -n "$rate" ]]; then
        printf "  $(pct_color "$rate")⏳%.0f%%\033[0m" "$rate"
    fi
fi

# MCP server count
mcp_count=$(jq '.mcpServers | length' ~/.claude.json 2>/dev/null)
if [[ -n "$mcp_count" && "$mcp_count" -gt 0 ]]; then
    printf "  \033[94m🔧%d\033[0m" "$mcp_count"
fi
